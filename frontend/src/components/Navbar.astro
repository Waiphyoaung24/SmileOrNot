---
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/', match: '/', code: 'M01', label: 'Smile' },
  { href: '/can/', match: '/can', code: 'M02', label: 'Can' },
];
---
<header class="hud-header">
  <div class="hud-brand">
    <span class="hud-brand-mark" aria-hidden="true">▣</span>
    <span class="hud-brand-name">VISION</span>
    <span class="hud-brand-version">v0.2.0</span>
  </div>

  <nav class="hud-nav" aria-label="Primary">
    {links.map((l) => (
      <a href={l.href} aria-current={path === l.match ? 'page' : undefined}>
        {l.code} · {l.label}
      </a>
    ))}
  </nav>

  <div class="hud-status" aria-live="polite">
    <span class="led" aria-hidden="true"></span>
    <span>Sys&nbsp;Online</span>
  </div>
</header>

<script>
  import { gsap } from 'gsap';

  function animateNav() {
    gsap.fromTo(
      '.hud-nav a',
      { y: -10, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.35, stagger: 0.06, ease: 'power2.out' },
    );
    gsap.fromTo(
      '.hud-brand',
      { x: -8, opacity: 0 },
      { x: 0, opacity: 1, duration: 0.35, ease: 'power2.out' },
    );
    gsap.fromTo(
      '.hud-status',
      { x: 8, opacity: 0 },
      { x: 0, opacity: 1, duration: 0.35, ease: 'power2.out' },
    );
  }

  animateNav();
  document.addEventListener('astro:after-swap', animateNav);
</script>
