---
import Base from '../layouts/Base.astro';
---
<Base title="Smile · Vision Lab">
  <section class="module">
    <span class="module-tag">Module&nbsp;01 / Smile</span>

    <h1 class="module-title">Are you <em>smiling</em>?</h1>
    <p class="module-sub">
      Real-time face-expression detection. Each face is boxed and labelled
      <code>smiling</code> or <code>neutral</code> with confidence.
    </p>

    <div class="control-bar">
      <span class="endpoint">Endpoint <strong>/predict</strong></span>
    </div>

    <div class="viewport" data-viewport>
      <span class="viewport-empty">Camera idle</span>
      <video id="video" playsinline autoplay muted></video>
      <canvas id="overlay" class="overlay"></canvas>
      <div class="viewport-bracket viewport-bracket-tl" aria-hidden="true"></div>
      <div class="viewport-bracket viewport-bracket-tr" aria-hidden="true"></div>
      <div class="viewport-bracket viewport-bracket-bl" aria-hidden="true"></div>
      <div class="viewport-bracket viewport-bracket-br" aria-hidden="true"></div>
    </div>

    <div class="stats">
      <div class="stat">
        <span class="stat-label">Faces</span>
        <span class="stat-value" data-stat="count">—</span>
      </div>
      <div class="stat">
        <span class="stat-label">Inference</span>
        <span class="stat-value"><span data-stat="ms">—</span> ms</span>
      </div>
      <span class="stat-meta" data-stat="classes">smiling · neutral</span>
    </div>

    <div class="actions">
      <button class="btn-primary" id="toggle">Start camera</button>
    </div>

    <p class="status-line" id="status">Awaiting input.</p>
  </section>

  <script>
    import '../scripts/app.js';
  </script>
</Base>
