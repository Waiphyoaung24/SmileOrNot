---
import Base from '../layouts/Base.astro';
---
<Base title="Can · Vision">
  <section class="module">
    <span class="module-tag">Module&nbsp;02 / Can</span>

    <h1 class="module-title">Detect any <em>can</em>.</h1>
    <p class="module-sub">
      Custom YOLO11n trained on 4 137 images. Use the camera or upload a photo.
    </p>

    <div class="control-bar">
      <div class="mode-toggle" role="tablist" aria-label="Input mode">
        <button role="tab" id="mode-live" aria-selected="true">Live</button>
        <button role="tab" id="mode-upload" aria-selected="false">Upload</button>
      </div>
      <span class="endpoint">Endpoint <strong>/predict/can</strong></span>
    </div>

    <section id="live-pane" class="live-pane">
      <div class="viewport" data-viewport>
        <span class="viewport-empty">Camera idle</span>
        <video id="video" playsinline autoplay muted></video>
        <canvas id="overlay-live" class="overlay"></canvas>
        <div class="viewport-bracket viewport-bracket-tl" aria-hidden="true"></div>
        <div class="viewport-bracket viewport-bracket-tr" aria-hidden="true"></div>
        <div class="viewport-bracket viewport-bracket-bl" aria-hidden="true"></div>
        <div class="viewport-bracket viewport-bracket-br" aria-hidden="true"></div>
      </div>
    </section>

    <section id="upload-pane" class="upload-pane" hidden>
      <div class="viewport" data-viewport>
        <span class="viewport-empty">No image yet</span>
        <img id="upload-image" alt="" />
        <canvas id="overlay-upload" class="overlay"></canvas>
        <div class="viewport-bracket viewport-bracket-tl" aria-hidden="true"></div>
        <div class="viewport-bracket viewport-bracket-tr" aria-hidden="true"></div>
        <div class="viewport-bracket viewport-bracket-bl" aria-hidden="true"></div>
        <div class="viewport-bracket viewport-bracket-br" aria-hidden="true"></div>
      </div>
    </section>

    <div class="stats">
      <div class="stat">
        <span class="stat-label">Targets</span>
        <span class="stat-value" data-stat="count">—</span>
      </div>
      <div class="stat">
        <span class="stat-label">Inference</span>
        <span class="stat-value"><span data-stat="ms">—</span> ms</span>
      </div>
      <span class="stat-meta">YOLO11n · mAP@50 0.96</span>
    </div>

    <div class="actions">
      <button class="btn-primary" id="toggle">Start camera</button>
      <button class="btn-secondary" id="flip" type="button" aria-label="Flip camera">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 8h13a4 4 0 0 1 4 4v1" />
          <polyline points="6 5 3 8 6 11" />
          <path d="M21 16H8a4 4 0 0 1-4-4v-1" />
          <polyline points="18 19 21 16 18 13" />
        </svg>
        Flip
      </button>
      <label class="upload-btn" id="upload-btn" hidden>
        Choose photo
        <input id="file-input" type="file" accept="image/*" />
      </label>
    </div>

    <p class="status-line" id="status">Awaiting input.</p>
  </section>

  <script>
    import '../scripts/can.js';
  </script>
</Base>
